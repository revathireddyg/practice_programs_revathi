<mvc:View
    controllerName="demo.first.firstproject.controller.App8"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin" width="20rem">

        <Title text="Email Validation" class="sapUiSmallMarginBottom"/>

        <Input
            id="emailInput"
            value="{/email}"
            liveChange="onLiveChange"
            placeholder="Enter email address" />

    </VBox>
</mvc:View>