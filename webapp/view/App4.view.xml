<mvc:View
    controllerName="demo.first.firstproject.controller.App4"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox class="sapUiSmallMargin" width="20rem">
        <Title text="Password Show/Hide Toggle" class="sapUiSmallMarginBottom" />

        <Input
            id="passwordInput"
            value="{/password}"
            type="{/inputType}"
            placeholder="Enter password" />

        <Button
            text="{/buttonText}"
            type="Emphasized"
            press="onTogglePassword"
            class="sapUiSmallMarginTop" />
    </VBox>
</mvc:View>