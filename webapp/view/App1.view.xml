<mvc:View
    controllerName="demo.first.firstproject.controller.App1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <VBox
        class="sapUiSmallMargin"
        justifyContent="Center"
        alignItems="Center">

        <Title text="Dynamic Button Text Binding" class="sapUiSmallMarginBottom" />

        <Button
            text="{/buttonText}"   
            type="Emphasized"
            press="onButtonPress"
            width="12rem" />      <!-- {} is used for data binding -->

    </VBox>
</mvc:View>